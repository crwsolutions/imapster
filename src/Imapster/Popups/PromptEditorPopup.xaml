<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="clr:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
               xmlns:vm="clr:Imapster.ViewModels"
               x:DataType="vm:PromptEditorPopupViewModel"
               x:Class="Imapster.Popups.PromptEditorPopup"
               Background="Black" WidthRequest="700">
    <ScrollView Padding="20" VerticalOptions="Center">
        <VerticalStackLayout Spacing="15" MaximumWidthRequest="800">
            <Label Text="AI Prompt Editor" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
            
            <Label Text="Edit the system prompt for email categorization:" FontSize="14" TextColor="Gray" />
            
            <Editor Text="{Binding PromptText}"
                    Placeholder="Prompt text..."
                    Multiline="True"
                    HorizontalOptions="FillAndExpand"
                    VerticalOptions="FillAndExpand"
                    HeightRequest="400"
                    FontFamily="Monospace"
                    FontSize="12"
                    Padding="12"
                    BackgroundColor="{StaticResource Gray700}"
                    TextColor="White"
                    Margin="0,0,0,10" />
            
            <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="10" Margin="0,10,0,0">
                <Button Text="Reset to Default" 
                        Command="{Binding ResetToDefaultCommand}"
                        BackgroundColor="{StaticResource Gray600}"
                        TextColor="White"
                        WidthRequest="150" />
                <Button Text="Save" 
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        BackgroundColor="Green"
                        TextColor="White"
                        WidthRequest="150" />
            </StackLayout>
            
            <BoxView Color="{StaticResource Gray600}" HeightRequest="1" Margin="0,20,0,10" />
            
            <Label Text="Output Format (Read-only Reference)" FontSize="14" FontAttributes="Bold" TextColor="LightBlue" />
            
            <Editor Text="{Binding DefaultPrompt, Mode=OneWay}"
                    IsReadOnly="True"
                    IsEnabled="False"
                    Multiline="True"
                    HorizontalOptions="FillAndExpand"
                    VerticalOptions="FillAndExpand"
                    HeightRequest="150"
                    FontFamily="Monospace"
                    FontSize="11"
                    Padding="12"
                    BackgroundColor="{StaticResource Gray800}"
                    TextColor="Gray"
                    Margin="0,0,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</toolkit:Popup>