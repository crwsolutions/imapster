<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
             xmlns:sys="clr-namespace:System.Collections.Generic;assembly=System.Runtime"
             x:TypeArguments="x:Object"
             x:Class="Imapster.ContentViews.Popups.ColumnFilterPopup">
    <Grid RowDefinitions="auto, *, auto" RowSpacing="8">
        <Label Text="Select Values to Filter" FontSize="18" FontAttributes="Bold" />
        
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="FilterItemsLayout" />
        </ScrollView>
        
        <Button Text="Apply" Clicked="OnApplyClicked" BackgroundColor="Blue" TextColor="White" Grid.Row="2" />
    </Grid>
</toolkit:Popup>