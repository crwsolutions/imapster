<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Imapster.ViewModels"
             xmlns:local="clr-namespace:Imapster.ContentViews"
             xmlns:viewer="clr-namespace:Imapster.HtmlViewer.Rendering;assembly=Imapster.HtmlViewer"
             x:Class="Imapster.ContentViews.EmailDetailsView"
             x:DataType="local:EmailDetailsView" Background="#060B1D"
             x:Name="ThisView" Padding="12,12,12,12">
    <Grid RowDefinitions="*, auto">
        <!-- Empty state when no email is selected -->
        <Grid x:Name="EmptyStateGrid" RowDefinitions="*" VerticalOptions="Center" IsVisible="True">
            <Label Text="Select an email to view details" 
                   HorizontalOptions="Center" 
                   VerticalOptions="Center" 
                   FontSize="18" 
                   TextColor="Gray"
                   Grid.Row="0" />
        </Grid>

        <!-- Email details content -->
        <Grid RowDefinitions="auto,*,auto" x:Name="DetailsScrollView" IsVisible="False" RowSpacing="12">

            <!-- email details -->
            <VerticalStackLayout>
                <Label Text="{Binding Source={x:Reference ThisView}, Path=Email.Subject}" Grid.Column="0" FontAttributes="Bold" FontSize="28" MaxLines="2" LineBreakMode="TailTruncation" />
                <Label Grid.Row="2" Grid.ColumnSpan="2" TextColor="{StaticResource Gray400}" Text="{Binding Source={x:Reference ThisView}, Path=Email.Date, StringFormat='{0:d MMMM yyyy HH:mm}'}" />

                <!-- FromDisplay pill and expandable details -->
                <Grid ColumnDefinitions="*, *, auto" Margin="0,10,0,5" RowSpacing="8">
                    <Grid ColumnDefinitions="Auto, Auto" x:Name="FromPill">
                        <Border Grid.Row="0" StrokeShape="RoundRectangle 22" StrokeThickness="0" Stroke="{StaticResource Gray400}" Background="#121A2C" Padding="18,0,18,0">
                            <Label Text="{Binding Source={x:Reference ThisView}, Path=Email.FromDisplay}" FontAttributes="Bold" VerticalOptions="Center" TextColor="{StaticResource Secondary}" Margin="5,0,0,0" />
                        </Border>
                    </Grid>

                    <Grid x:Name="FromToDetailsGrid" IsVisible="False" ColumnDefinitions="80, auto, auto" RowDefinitions="auto,auto" RowSpacing="8" Grid.Row="1">
                        <Label Grid.Row="0" Text="From:" Margin="0,4,0,0" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Source={x:Reference ThisView}, Path=Email.From}" FontAttributes="Bold" Margin="5,4,0,0" TextColor="{StaticResource Secondary}" />
                        <Label Grid.Row="1" Text="To:" Margin="0,4,0,0" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Source={x:Reference ThisView}, Path=Email.To}" Margin="5,4,0,0" />
                    </Grid>
                    <Button Grid.Column="1" x:Name="ToggleFromButton" Text="Gegevens" Clicked="ToggleFromButtonClicked" BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="14" WidthRequest="100" HeightRequest="28" Margin="8,0,0,0" />

                    <local:ToggleSwitchView Grid.Row="0" Grid.Column="2" VerticalOptions="End" LeftText="HTML" RightText="RAW" Margin="0,0,0,6" Toggled="ToggleSwitchView_Toggled" />
                </Grid>

            </VerticalStackLayout>

            <!-- Body -->
            <Border StrokeShape="RoundRectangle 6" Padding="12" StrokeThickness="0" Grid.Row="1" Background="#DDFFFFFF">
                <Grid>
                    <Grid x:Name="HtmlContentGrid" IsVisible="True" Grid.Row="2">
                        <ScrollView VerticalScrollBarVisibility="Always">
                            <viewer:HtmlViewer Html="{Binding Source={x:Reference ThisView}, Path=Email.BodyHtml}" />
                        </ScrollView>
                    </Grid>
                    <Grid x:Name="RawContentGrid" IsVisible="False" Grid.Row="2">
                        <Editor IsReadOnly="True" Text="{Binding Source={x:Reference ThisView}, Path=Email.Body}" TextColor="{StaticResource Gray950}" />
                    </Grid>
                </Grid>
            </Border>

            <!-- attachement and AI information -->
            <VerticalStackLayout Grid.Row="2">
                <!--<BoxView HeightRequest="1" BackgroundColor="Gray" Margin="0,10,0,10" />-->
                <Label Text="Attachments:" FontAttributes="Bold" Margin="0,5,0,8" />
                <CollectionView ItemsSource="{Binding Source={x:Reference ThisView}, Path=Email.AttachmentList, Mode=OneWay}" Margin="0,0,0,10">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:AttachmentViewModel">
                            <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray400}" VerticalOptions="Start" Padding="8" Margin="0,0,0,5">
                                <Grid ColumnDefinitions="Auto, Auto, Auto" ColumnSpacing="10" VerticalOptions="Start">
                                    <Label Text="{Binding FileName}" Grid.Column="0" VerticalOptions="Center" TextColor="White" />
                                    <Button Text="Archive" Grid.Column="1" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EmailViewModel}}, Path=ArchiveAttachmentCommand}"
                                            CommandParameter="{Binding .}"
                                            WidthRequest="80"
                                            HeightRequest="30" />
                                    <Button Text="Open" Grid.Column="2" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EmailViewModel}}, Path=OpenAttachmentCommand}"
                                            CommandParameter="{Binding .}"
                                            WidthRequest="80"
                                            HeightRequest="30" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!--<BoxView HeightRequest="1" BackgroundColor="Gray" Margin="0,10,0,10" />-->
                <HorizontalStackLayout>
                    <Label Text="&#xe2ca;" FontFamily="FontAwesomeSolid" FontAttributes="Bold" VerticalTextAlignment="Center" Margin="8,3,12,0" FontSize="24" TextColor="{StaticResource Primary}" />
                    <Label Text="AI INFORMATION" VerticalOptions="Center" VerticalTextAlignment="Center" FontSize="18" TextColor="{StaticResource Primary}"  />
                </HorizontalStackLayout>

                <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="auto, auto, auto, auto" Margin="0,5,0,5" RowSpacing="12" ColumnSpacing="12">
                    <Border Stroke="#1B2437" Background="#121A2C" StrokeShape="RoundRectangle 12" Padding="12" Grid.ColumnSpan="2">
                        <VerticalStackLayout>
                            <Label Text="Summary" TextTransform="Uppercase" FontAttributes="Bold" Margin="0,0,0,8" />
                            <Label Text="{Binding Source={x:Reference ThisView}, Path=Email.AiSummary}" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Stroke="#1B2437" Background="#121A2C" StrokeShape="RoundRectangle 12" Padding="12" Grid.Column="2">
                        <VerticalStackLayout>
                            <Label Text="Category" TextTransform="Uppercase" FontAttributes="Bold" Margin="0,0,0,8" />
                            <Label Text="{Binding Source={x:Reference ThisView}, Path=Email.AiCategory}"  />
                        </VerticalStackLayout>
                    </Border>
                    <Border Stroke="#1B2437" Background="#121A2C" StrokeShape="RoundRectangle 12" Padding="12" Grid.Row="1">
                        <VerticalStackLayout>
                            <Label Text="Delete ?" TextTransform="Uppercase" FontAttributes="Bold" Margin="0,0,0,12"/>
                            <Grid ColumnDefinitions="22, *">
                                <Label Text="&#xf058;" TextColor="#48C08F" FontFamily="FontAwesomeSolid" VerticalTextAlignment="Center" IsVisible="{Binding Source={x:Reference ThisView}, Path=Email.AiDelete}" />
                                <Label Text="&#xf058;" TextColor="#F87171" FontFamily="FontAwesomeSolid" VerticalTextAlignment="Center" IsVisible="{Binding Source={x:Reference ThisView}, Path=Email.AiDelete, FallbackValue=False, Converter={StaticResource InvertedBoolConverter}}" />
                                <Label Grid.Column="1" Text="Save to delete" TextColor="#48C08F" VerticalTextAlignment="Center" IsVisible="{Binding Source={x:Reference ThisView}, Path=Email.AiDelete}" />
                                <Label Grid.Column="1" Text="Do not delete" TextColor="#F87171" VerticalTextAlignment="Center" IsVisible="{Binding Source={x:Reference ThisView}, Path=Email.AiDelete, FallbackValue=False, Converter={StaticResource InvertedBoolConverter}}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                    <Border Stroke="#1B2437" Background="#121A2C" StrokeShape="RoundRectangle 12" Padding="12" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1">
                        <VerticalStackLayout>
                            <Label Text="Motivation" TextTransform="Uppercase" FontAttributes="Bold" Margin="0,0,0,8" />
                            <Label Text="{Binding Source={x:Reference ThisView}, Path=Email.AiDeleteMotivation}" FontAttributes="Italic" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                    <local:GlyphMaterialButton Text="Redo AI" Glyph="&#xf2f9;"
                        Command="{Binding Source={x:Reference ThisView}, Path=Email.RedoAiClassificationCommand}"
                        BackgroundColor="Blue" 
                        TextColor="White" 
                        WidthRequest="150" />
                    <local:GlyphMaterialButton Text="Re-fetch" Glyph="&#xf0ed;"
                        Command="{Binding Source={x:Reference ThisView}, Path= Email.ReFetchEmailCommand}"
                        BackgroundColor="Orange" 
                        TextColor="White" 
                        WidthRequest="150" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Grid>

        <HorizontalStackLayout Spacing="8" Grid.Row="1" IsVisible="False">
            <ActivityIndicator IsRunning="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=IsBusy}" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="18" HeightRequest="18" />
            <Label Text="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=Status}" />
        </HorizontalStackLayout>
    </Grid>
</ContentView>
