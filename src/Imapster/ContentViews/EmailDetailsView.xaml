<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Imapster.ViewModels"
             xmlns:local="clr-namespace:Imapster.ContentViews"
             xmlns:viewer="clr-namespace:Imapster.HtmlViewer.Rendering;assembly=Imapster.HtmlViewer"
             x:Class="Imapster.ContentViews.EmailDetailsView"
             x:DataType="local:EmailDetailsView"
             x:Name="ThisView">
    <Grid RowDefinitions="*, auto">
        <!-- Empty state when no email is selected -->
        <Grid x:Name="EmptyStateGrid" RowDefinitions="*" VerticalOptions="Center" IsVisible="True">
            <Label Text="Select an email to view details" 
                   HorizontalOptions="Center" 
                   VerticalOptions="Center" 
                   FontSize="18" 
                   TextColor="Gray"
                   Grid.Row="0" />
        </Grid>

        <!-- Email details content -->
        <ScrollView x:Name="DetailsScrollView" Padding="10" IsVisible="False">
            <Grid RowDefinitions="auto,*,auto">

                <!-- email details -->
                <VerticalStackLayout>
                    <Grid ColumnDefinitions="Auto, *" Margin="0,5,0,5" ColumnSpacing="12">
                        <Label Text="Subject:" FontAttributes="Bold" Grid.Column="0" />
                        <Label Text="{Binding Source={x:Reference ThisView}, Path=Email.Subject}" Grid.Column="1" FontAttributes="Bold" />
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="Gray" Margin="0,10,0,10" />

                    <Grid ColumnDefinitions="Auto, *" Margin="0,5,0,5">
                        <Label Text="From:" FontAttributes="Bold" Grid.Column="0" />
                        <Label Text="{Binding Source={x:Reference ThisView}, Path=Email.From}" Grid.Column="1" Margin="5,0,0,0" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto, *" Margin="0,5,0,5">
                        <Label Text="To:" FontAttributes="Bold" Grid.Column="0" />
                        <Label Text="{Binding Source={x:Reference ThisView}, Path=Email.To}" Grid.Column="1" Margin="5,0,0,0" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto, *, auto" Margin="0,5,0,5">
                        <Label Text="Date:" FontAttributes="Bold" Grid.Column="0" />
                        <Label Text="{Binding Source={x:Reference ThisView}, Path=Email.Date}" Grid.Column="1" Margin="5,0,0,0" />
                        <Label Text="{Binding Source={x:Reference ThisView}, Path=Email.FolderId}" Grid.Column="2" Margin="5,0,0,0" />
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="Gray" Margin="0,10,0,10" />

                </VerticalStackLayout>

                <!-- Body -->
                <Grid RowDefinitions="auto, auto, *" Grid.Row="1">
                    <Label Text="Body:" FontAttributes="Bold" Margin="0,5,0,8" />
                    <HorizontalStackLayout Margin="0,0,0,5" Spacing="2" Grid.Row="1">
                        <Button x:Name="HtmlTabButton" Text="Html" 
                            BackgroundColor="{StaticResource Primary}" 
                            TextColor="White"
                            Clicked="OnHtmlTabClicked"
                            WidthRequest="150" HeightRequest="20" />
                        <Button x:Name="RawTabButton" Text="Raw" 
                            BackgroundColor="Gray" 
                            TextColor="White"
                            Clicked="OnRawTabClicked"
                            WidthRequest="150" HeightRequest="20" />
                    </HorizontalStackLayout>
                    <Grid x:Name="HtmlContentGrid" IsVisible="True" Grid.Row="2">
                        <Border StrokeShape="RoundRectangle 6" Background="White" Padding="12" StrokeThickness="0">
                            <ScrollView HeightRequest="300" VerticalScrollBarVisibility="Always">
                                <viewer:HtmlViewer Html="{Binding Source={x:Reference ThisView}, Path=Email.BodyHtml}" />
                            </ScrollView>
                        </Border>
                    </Grid>
                    <Grid x:Name="RawContentGrid" IsVisible="False" Grid.Row="2">
                        <Border StrokeShape="RoundRectangle 6" Background="White" Padding="12" StrokeThickness="0">
                            <ScrollView HeightRequest="300" VerticalScrollBarVisibility="Always">
                                <Label Text="{Binding Source={x:Reference ThisView}, Path=Email.Body}" TextColor="{StaticResource Gray950}" LineBreakMode="WordWrap" />
                            </ScrollView>
                        </Border>
                    </Grid>
                </Grid>

                <!-- attachement and AI information -->
                <VerticalStackLayout Grid.Row="2">
                    <BoxView HeightRequest="1" BackgroundColor="Gray" Margin="0,10,0,10" />
                    <Label Text="Attachments:" FontAttributes="Bold" Margin="0,5,0,8" />
                    <CollectionView ItemsSource="{Binding Source={x:Reference ThisView}, Path=Email.AttachmentList, Mode=OneWay}" Margin="0,0,0,10">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:AttachmentViewModel">
                                <Border StrokeShape="Rectangle" StrokeThickness="1" Stroke="{StaticResource Gray400}" Padding="8" Margin="0,0,0,5">
                                    <Grid ColumnDefinitions="Auto, Auto, Auto" ColumnSpacing="10">
                                        <Label Text="{Binding FileName}" Grid.Column="0" VerticalOptions="Center" TextColor="White" />
                                        <Button Text="Archive" Grid.Column="1" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=ArchiveAttachmentCommand}"
                                            CommandParameter="{Binding .}"
                                            WidthRequest="80"
                                            HeightRequest="30" />
                                        <Button Text="Open" Grid.Column="2" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=OpenAttachmentCommand}"
                                            CommandParameter="{Binding .}"
                                            WidthRequest="80"
                                            HeightRequest="30" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <BoxView HeightRequest="1" BackgroundColor="Gray" Margin="0,10,0,10" />

                    <Label Text="AI Information:" FontAttributes="Bold" Margin="0,5,0,5" />

                    <Grid ColumnDefinitions="Auto, *" RowDefinitions="auto, auto, auto, auto" Margin="0,5,0,5" RowSpacing="8">
                        <Label Text="Summary:" FontAttributes="Bold" Grid.Column="0" />
                        <Label Text="{Binding Source={x:Reference ThisView}, Path=Email.AiSummary}" Grid.Column="1" Margin="5,0,0,0" />
                        <Label Text="Category:" FontAttributes="Bold" Grid.Column="0" Grid.Row="1" />
                        <Label Text="{Binding Source={x:Reference ThisView}, Path=Email.AiCategory}" Grid.Column="1" Margin="5,0,0,0" Grid.Row="1" />
                        <Label Text="Delete:" FontAttributes="Bold" Grid.Column="0" Grid.Row="2" />
                        <Label Text="{Binding Source={x:Reference ThisView}, Path=Email.AiDelete}" Grid.Column="1" Margin="5,0,0,0" Grid.Row="2" />
                        <Label Text="Delete Motivation:" FontAttributes="Bold" Grid.Column="0" Grid.Row="3" />
                        <Label Text="{Binding Source={x:Reference ThisView}, Path=Email.AiDeleteMotivation}" Grid.Column="1" Margin="5,0,0,0" Grid.Row="3" />
                    </Grid>

                    <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                        <Button Text="Redo AI" 
                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=RedoAiClassificationCommand}"
                        CommandParameter="{Binding .}"
                        BackgroundColor="Blue" 
                        TextColor="White" 
                        WidthRequest="150" />
                        <Button Text="Re-fetch" 
                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=ReFetchEmailCommand}"
                        CommandParameter="{Binding .}"
                        BackgroundColor="Orange" 
                        TextColor="White" 
                        WidthRequest="150" />
                        <Button Text="Edit Prompt" 
                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=EditPromptCommand}"
                        BackgroundColor="Green" 
                        TextColor="White" 
                        WidthRequest="150" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>
        </ScrollView>
        <HorizontalStackLayout Spacing="8" Grid.Row="1" IsVisible="False">
            <ActivityIndicator IsRunning="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=IsBusy}" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="18" HeightRequest="18" />
            <Label Text="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=Status}" />
        </HorizontalStackLayout>
    </Grid>
</ContentView>
