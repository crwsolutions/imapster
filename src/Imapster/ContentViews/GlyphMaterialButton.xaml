<?xml version="1.0" encoding="utf-8" ?>
<Border xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:cv="clr-namespace:Imapster.ContentViews"
             x:Class="Imapster.ContentViews.GlyphMaterialButton"
             x:Name="ThisContentView"
             x:DataType="cv:GlyphMaterialButton"
             HeightRequest="44"
             StrokeThickness="2"
             Stroke="{Binding BorderColor, Source={x:Reference Name=ThisContentView}}"
             BackgroundColor="{Binding ButtonColor, Source={x:Reference Name=ThisContentView}}">
    <cv:ImapsterMaterialButton RippleColor="{Binding RippleColor, Source={x:Reference Name=ThisContentView}}"
                           Command="{Binding Command, Source={x:Reference Name=ThisContentView}}" Clicked="MaterialButton_Clicked">
        <Grid ColumnDefinitions="auto, auto, auto" ColumnSpacing="12" VerticalOptions="Center" HorizontalOptions="Center">
            <Label FontFamily="{Binding FontFamily, Source={x:Reference Name=ThisContentView}}"
                   VerticalTextAlignment="Center"
                   FontAttributes="Bold"
                   Text="{Binding Glyph, Source={x:Reference Name=ThisContentView}}"
                   TextColor="{Binding TextColor, Source={x:Reference Name=ThisContentView}}"/>
            <Label Grid.Column="1"
                   FontSize="14"
                   LineBreakMode="TailTruncation"
                   VerticalTextAlignment="Center"
                   Text="{Binding Text, Source={x:Reference Name=ThisContentView}}"
                   TextColor="{Binding TextColor, Source={x:Reference Name=ThisContentView}}"/>
            <Label Grid.Column="2" Text="&#xf105;" VerticalTextAlignment="Center" FontFamily="FontAwesomeSolid" FontSize="14"  TextColor="{Binding TextColor, Source={x:Reference Name=ThisContentView}}" IsVisible="{Binding Source={x:Reference Name=ThisContentView}, Path=ShowForwardNavigationIcon}"/>
        </Grid>
    </cv:ImapsterMaterialButton>
</Border>
