<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Imapster.ViewModels"
             xmlns:local="clr-namespace:Imapster.ContentViews"
             x:Class="Imapster.ContentViews.TreeView"
             x:Name="ContentView">

    <ScrollView BackgroundColor="{StaticResource Gray600}">
        <CollectionView x:Name="FolderCollection" 
                        ItemsSource="{Binding ItemsSource, Source={x:Reference Name=ContentView}}" 
                        SelectedItem="{Binding SelectedItem, Source={x:Reference Name=ContentView}}"
                        SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:FolderViewModel">
                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="12,4,12,4" BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToSelectionColorConverter}}">
                        <!-- Expand/Collapse Toggle -->
                        <Label Text="▶"
                               FontSize="8"
                               VerticalOptions="Center"
                               IsVisible="{Binding HasChildren}"
                               Grid.Column="0"
                               Margin="2,0,4,0"
                               TextColor="Gray"/>
                        
                        <!-- Folder Name with Indentation -->
                        <Label Text="{Binding Name}"
                               VerticalOptions="Center"
                               Grid.Column="1"
                               Margin="{Binding IndentLevel, Converter={StaticResource IntToThicknessConverter}}"/>
                        
                        <!-- Unread Count -->
                        <!--<Label Text="{Binding UnreadCount}"
                               FontSize="10"
                               TextColor="Gray"
                               VerticalOptions="Center"
                               Grid.Column="2"
                               IsVisible="{Binding UnreadCount, Converter={StaticResource InvertedBoolConverter}}"/>-->
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </ScrollView>
</ContentView>